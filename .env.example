# ============================================================
# INNA AI COPILOT MULTICHANNEL
# Arquivo de exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais
# ============================================================


# ============================================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ============================================================

APP_NAME=inna-ai-copilot-multichannel
APP_VERSION=1.0.0
APP_ENV=development


# ============================================================
# CONFIGURAÇÕES DA API FASTAPI
# ============================================================

API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000


# ============================================================
# CONFIGURAÇÕES DA IA GENERATIVA - GEMINI
# ============================================================

# true = usa respostas simuladas sem gastar API
# false = usa Gemini real
INNA_MOCK_MODE=true

# Chave da API Gemini
# Nunca coloque sua chave real no GitHub
GEMINI_API_KEY=coloque_sua_chave_gemini_aqui

# Modelo utilizado no projeto
GEMINI_MODEL=gemini-2.5-flash-lite


# ============================================================
# CANAIS DE ATENDIMENTO
# ============================================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=coloque_seu_token_telegram_aqui

# Gmail Bot
GMAIL_USER=innaassistente@gmail.com


# ============================================================
# N8N / WEBHOOKS
# ============================================================

# URL local do n8n
N8N_LOCAL_URL=http://localhost:5678

# URL pública usada com ngrok durante desenvolvimento
N8N_WEBHOOK_URL=https://seu-link-ngrok-aqui.ngrok-free.app


# ============================================================
# ARQUIVOS DE DADOS LOCAIS
# ============================================================

DATA_DIR=data
PROFILE_FILE=data/perfil_usuario.json
TRANSACTIONS_FILE=data/transacoes.csv
INTERACTIONS_LOG_FILE=data/interacoes_inna.csv
FEEDBACK_FILE=data/feedbacks.csv


# ============================================================
# BANCO DE DADOS
# ============================================================

# No Projeto 1, o projeto usa CSV/JSON.
# PostgreSQL fica como evolução futura para o Projeto 2.
DATABASE_URL=


# ============================================================
# SEGURANÇA
# ============================================================

# Não enviar dados sensíveis reais para a aplicação.
# O projeto utiliza dados fictícios para demonstração.
USE_FAKE_DATA=true

